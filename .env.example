APP_NAME="MineVida Network"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Mexico_City
APP_URL=http://127.0.0.1:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_MX

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lumoryx_postulaciones
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

MINEVIDA_SERVER_IP=play.minevida.net
MINEVIDA_SERVER_VERSION="Java 1.20+"
MINEVIDA_DISCORD_WIDGET_ID=1422483289767153686
MINEVIDA_DISCORD_URL=https://discord.gg/minevida
MINEVIDA_STORE_URL=
MINEVIDA_TIKTOK_URL=
MINEVIDA_YOUTUBE_URL=2
MINEVIDA_INSTAGRAM_URL=

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI="${APP_URL}/login/discord/callback"
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_STAFF_CHANNEL_ID=
DISCORD_BOT_API_URL=http://127.0.0.1:3001
INTERNAL_BOT_API_TOKEN=
# Opcional. Dejalo vacio para que el bot adjunte public/images/MineVidaLogo.png en los embeds.
DISCORD_EMBED_ICON_URL=https://media.discordapp.net/attachments/1505844327329304627/1506505572814422108/logoofi.png?ex=6a0e8226&is=6a0d30a6&hm=58dd2c3eb5136bb2eba3e1a60fd5cfbbd3a343f31ebbf8e2ca39826d617f2de3&=&format=webp&quality=lossless&width=939&height=939
DISCORD_SYSTEM_LOGS_ENABLED=true
# Canal privado donde el sistema mandara logs de auditoria. Puedes usar varios IDs separados por coma o espacio.
DISCORD_SYSTEM_LOG_CHANNEL_ID=1506089175433351280
DISCORD_SYSTEM_LOG_EVENTS=applications,status,interviews,categories,settings,users,selected,auth,discord

