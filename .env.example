APP_NAME="MineVida Network"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=America/Mexico_City
APP_URL=https://tu-dominio.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_MX

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=postulaciones
DB_USERNAME=app_user
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
# En produccion con HTTPS usa true. En local con http puedes cambiarlo a false.
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@tu-dominio.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Marca y comunidad. Solo datos publicos/no sensibles.
COMMUNITY_LOGO_PATH=images/MineVidaLogo.png
COMMUNITY_PUBLIC_BACKGROUND_PATH=images/lumo_fondo.png
COMMUNITY_SIDEBAR_BACKGROUND_PATH=images/slidebar.png
COMMUNITY_SERVER_IP=play.minevida.net
COMMUNITY_SERVER_VERSION="Java 1.20+"
COMMUNITY_SERVER_MODE="Survival OP"
COMMUNITY_SERVER_PLAYERS_LABEL="Comunidad activa"
COMMUNITY_SERVER_PERFORMANCE="TPS 20.0"
COMMUNITY_DISCORD_WIDGET_ID=
COMMUNITY_DISCORD_URL=
COMMUNITY_STORE_URL=
COMMUNITY_TIKTOK_URL=
COMMUNITY_YOUTUBE_URL=
COMMUNITY_INSTAGRAM_URL=

# Imagenes opcionales para embeds de Discord. Usa URLs publicas permanentes; no pegues enlaces temporales con tokens.
DISCORD_STATUS_PENDING_IMAGE_URL=
DISCORD_STATUS_IN_REVIEW_IMAGE_URL=
DISCORD_STATUS_INTERVIEW_IMAGE_URL=
DISCORD_STATUS_ACCEPTED_IMAGE_URL=
DISCORD_STATUS_REJECTED_IMAGE_URL=

# Valores iniciales del sistema. Luego el owner puede cambiarlos desde el panel.
APPLICATIONS_OPEN_BY_DEFAULT=true
APPLICATION_MINIMUM_AGE=15
APPLICATION_REAPPLY_COOLDOWN_DAYS=14
APPLICATION_REQUIRE_DISCORD_GUILD=false

# OAuth/Bot Discord. Estos valores son sensibles: mantenlos solo en .env real.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI="${APP_URL}/login/discord/callback"
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_STAFF_CHANNEL_ID=
DISCORD_BOT_API_URL=http://127.0.0.1:3001
INTERNAL_BOT_API_TOKEN=
# Opcional. Dejalo vacio para que el bot adjunte public/images/MineVidaLogo.png en los embeds.
DISCORD_EMBED_ICON_URL=
DISCORD_SYSTEM_LOGS_ENABLED=false
# Canal privado donde el sistema mandara logs de auditoria. Puedes usar varios IDs separados por coma o espacio.
DISCORD_SYSTEM_LOG_CHANNEL_ID=
DISCORD_SYSTEM_LOG_EVENTS=applications,status,interviews,categories,settings,users,selected,auth,discord
